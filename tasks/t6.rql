?g1 = "baz.ttl" .
?g2 = "normBaz.ttl" .
?g3 = "foo.ttl" .
?g4 = "normFoo.ttl" .
?g5 = "bar.ttl" .
?g6 = "normBar.ttl" .

?gExcluder = init ?g1 ?g2 .
?g1 = init ?g3 ?g4 .
?g2 = init ?g5 ?g6 .

(
    (
        SELECT (?s, ?p, ?o) FROM (?g1)
        UNION
        SELECT (?s, ?p, ?o) FROM (?g2)
    )
    DIFF
    SELECT (?s, ?p, ?o) FROM (?gExcluder)
)